data/** filter=lfs diff=lfs merge=lfs -text
outputs/** filter=lfs diff=lfs merge=lfs -text
# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare files that should always have CRLF line endings on checkout
*.bat text eol=crlf

# Explicitly declare files that should always have LF line endings on checkout
*.py text eol=lf
*.sh text eol=lf
