# --- Environments ---
# Python virtual environments
.env
.venv
env/
venv/
mvenv/

# --- Python Cache & Dependencies ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# --- Data Files ---
# Ignore all data directories. Data should be downloaded via a script.
data/
geotiff_downloads/
shapefiles_output/

# --- Models ---
# Ignore all model files. Models should be generated by training scripts.
models/
*.h5
*.joblib
*.json
*.keras
*.pt
*.pth
*.onnx

# --- Outputs & Results ---
# Ignore all outputs, figures, logs, and generated files
outputs/
# Ignore data and plot files
*.xlsx
*.xls
*.rds
*.html
*.txt

# Ignore documents and shortcuts
*.docx
*.pptx
*.lnk
*.pdf

__pycache__/
*.pyc
*.csv
*.png
*.jpeg
*.tif
*.tiff
*.nc
*.log
*.sqlite3
*.zip

# --- IDE & OS Specific ---
.idea/
.vscode/
.DS_Store
*.swp

# --- Jupyter Notebooks ---
.ipynb_checkpoints/

# --- R Project Files (if any) ---
.RData
.Rhistory
.Rproj.user

# --- Exception ---
# But DO track .gitkeep files so we can keep empty directories if needed.
# This ensures that a directory structure like 'outputs/figures/' can exist
# in the repo even if it's empty.
!.gitkeep
everything-claude-code/
.worktrees/
